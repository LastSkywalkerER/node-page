# Agent-only env (Docker: mounted as /app/.env). Safe to commit as a template.
# Copy to .env.agent and edit:  cp .env.agent.example .env.agent
#
# MAIN_NODE_URL — base URL of the main API (no trailing slash).
# NODE_ACCESS_TOKEN — from agent Connect response or main Admin → Nodes → Regenerate token.

MAIN_NODE_URL=http://host.docker.internal:8080
NODE_ACCESS_TOKEN=
